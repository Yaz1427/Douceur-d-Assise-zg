{% comment %}
  Douceur d'Assise - Product Card Snippet
  Card produit avec badges de confiance et design optimise seniors
  
  Usage: {% render 'da-card-product', product: product %}
{% endcomment %}

{%- liquid
  assign product = card_product | default: product
  assign product_url = product.url
  assign featured_image = product.featured_image
  assign price = product.price | money_without_trailing_zeros
  assign compare_price = product.compare_at_price
  assign on_sale = false
  if compare_price > product.price
    assign on_sale = true
  endif
-%}

<article class="da-product-card">
  <div class="da-product-card__image">
    <a href="{{ product_url }}" aria-label="Voir {{ product.title }}">
      {%- if featured_image -%}
        <img 
          src="{{ featured_image | image_url: width: 600 }}" 
          alt="{{ featured_image.alt | default: product.title }}"
          width="600"
          height="{{ 600 | divided_by: featured_image.aspect_ratio | round }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="da-product-card__placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
      {%- endif -%}
    </a>
    
    <!-- Badges de confiance -->
    <div class="da-product-card__badges">
      <span class="da-product-card__badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
        Livraison GRATUITE
      </span>
      {%- if on_sale -%}
        <span class="da-product-card__badge da-product-card__badge--secondary">
          Promo
        </span>
      {%- endif -%}
    </div>
  </div>

  <div class="da-product-card__content">
    <h3 class="da-product-card__title">
      <a href="{{ product_url }}">{{ product.title }}</a>
    </h3>
    
    <div class="da-product-card__price">
      {{ price }}
      {%- if on_sale -%}
        <span class="da-product-card__price-old">{{ compare_price | money_without_trailing_zeros }}</span>
      {%- endif -%}
    </div>

    <div class="da-product-card__shipping">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
      Garantie 30 jours
    </div>

    <div class="da-product-card__cta">
      {%- if product.available -%}
        <a href="{{ product_url }}" class="da-btn da-btn-primary">
          Voir le produit
        </a>
      {%- else -%}
        <button class="da-btn da-btn-secondary" disabled>
          Rupture de stock
        </button>
      {%- endif -%}
    </div>
  </div>
</article>
