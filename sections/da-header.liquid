{% comment %}
  Douceur d'Assise - Header Section
  Optimise pour seniors avec zones de clic larges et lisibilite
{% endcomment %}

<header class="da-header">
  <!-- Top bar avec confiance -->
  <div class="da-header__topbar">
    <div class="da-header__topbar-inner">
      <span class="da-header__topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Entreprise francaise
      </span>
      <span class="da-header__topbar-sep">•</span>
      <span class="da-header__topbar-item">
        <a href="tel:{{ section.settings.phone | default: '0186261020' }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ section.settings.phone | default: '01 86 26 10 20' }}
        </a>
      </span>
      <span class="da-header__topbar-sep">•</span>
      <span class="da-header__topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
        Livraison gratuite en France
      </span>
    </div>
  </div>

  <!-- Navigation principale -->
  <nav class="da-header__nav" role="navigation" aria-label="Navigation principale">
    <div class="da-header__nav-inner">
      <!-- Logo -->
      <div class="da-header__logo">
        <a href="/" aria-label="{{ shop.name }} - Accueil">
          {%- if section.settings.logo != blank -%}
            <img 
              src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}" 
              alt="{{ shop.name }}"
              width="{{ section.settings.logo_width }}"
              height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
              loading="eager"
            >
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
      </div>

      <!-- Links desktop -->
      <div class="da-header__links">
        <a href="/">Accueil</a>
        <a href="/collections/all">Catalogue</a>
        <a href="/pages/a-propos">A propos</a>
        <a href="/pages/contact">Contact</a>
      </div>

      <!-- Actions -->
      <div class="da-header__actions">
        <!-- Panier -->
        <a href="/cart" class="da-header__cart" id="da-cart-link" aria-label="Panier - {{ cart.item_count }} article(s)">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          <span class="da-header__cart-label">Panier</span>
          <span class="da-header__cart-badge" id="da-cart-badge" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
            {{ cart.item_count }}
          </span>
        </a>

        <!-- Burger mobile -->
        <button 
          class="da-header__burger" 
          id="da-burger" 
          aria-expanded="false" 
          aria-controls="da-mobile-menu"
          aria-label="Ouvrir le menu"
        >
          <svg id="da-icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg id="da-icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Menu mobile -->
    <div class="da-header__mobile" id="da-mobile-menu" aria-hidden="true">
      <div class="da-header__mobile-inner">
        <a href="/">Accueil</a>
        <a href="/collections/all">Catalogue</a>
        <a href="/pages/a-propos">A propos</a>
        <a href="/pages/contact">Contact</a>
        <a href="/cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline; vertical-align: middle; margin-right: 0.5rem;"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          Panier ({{ cart.item_count }})
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
(function() {
  // Mobile menu toggle
  var btn = document.getElementById('da-burger');
  var menu = document.getElementById('da-mobile-menu');
  var iconM = document.getElementById('da-icon-menu');
  var iconX = document.getElementById('da-icon-close');
  
  if (btn && menu) {
    btn.addEventListener('click', function() {
      var open = menu.classList.toggle('is-open');
      menu.setAttribute('aria-hidden', !open);
      btn.setAttribute('aria-expanded', open);
      btn.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      if (iconM) iconM.style.display = open ? 'none' : '';
      if (iconX) iconX.style.display = open ? '' : 'none';
    });
  }

  // Cart badge animation on update
  var badge = document.getElementById('da-cart-badge');
  if (badge) {
    document.addEventListener('cart:updated', function(e) {
      var count = e.detail && e.detail.item_count;
      if (typeof count !== 'undefined') {
        badge.textContent = count;
        badge.style.display = count > 0 ? '' : 'none';
        badge.classList.remove('is-updating');
        void badge.offsetWidth;
        badge.classList.add('is-updating');
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "En-tete DA",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 160
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Numero de telephone",
      "default": "01 86 26 10 20"
    }
  ]
}
{% endschema %}
