{% comment %}
  Douceur d'Assise - Featured Products Section
  Section produits vedettes pour la page d'accueil
{% endcomment %}

<section class="da-featured-products">
  <div class="da-featured-products__inner">
    <div class="da-featured-products__header">
      <h2 class="da-featured-products__title">{{ section.settings.title | default: 'Nos coussins ergonomiques' }}</h2>
      <p class="da-featured-products__subtitle">{{ section.settings.subtitle | default: 'Decouvrez notre selection de coussins pour soulager vos douleurs' }}</p>
    </div>
    
    <div class="da-featured-products__grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: section.settings.products_to_show -%}
          {% render 'da-card-product', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.products_to_show -%}
          {% render 'da-card-product', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
    
    {%- if section.settings.show_view_all -%}
      <div class="da-featured-products__cta">
        <a href="{{ section.settings.collection.url | default: routes.all_products_collection_url }}" class="da-btn da-btn-secondary">
          Voir tous nos produits
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Produits Vedettes",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Nos coussins ergonomiques"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Decouvrez notre selection de coussins pour soulager vos douleurs"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Nombre de produits"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Afficher le bouton 'Voir tous'",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Produits Vedettes"
    }
  ]
}
{% endschema %}
