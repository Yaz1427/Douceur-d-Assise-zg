{%- comment -%}
  Section formulaire de contact
{%- endcomment -%}

<section class="da-contact">
  <div class="da-contact__inner">
    <div class="da-contact__info">
      <h2>{{ section.settings.title | default: 'Contactez-nous' }}</h2>
      <p>{{ section.settings.description | default: 'Une question ? Notre equipe francaise est a votre ecoute du lundi au vendredi.' }}</p>
      
      <div class="da-contact__details">
        <div class="da-contact__detail">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span><strong>01 86 26 10 20</strong></span>
        </div>
        <div class="da-contact__detail">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>contact@douceurdassise.fr</span>
        </div>
        <div class="da-contact__detail">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Lun-Ven : 9h - 18h</span>
        </div>
      </div>
      
      <div style="margin-top: 2rem; padding: 1.5rem; background: var(--success-10); border-radius: var(--radius-xl); border-left: 4px solid var(--success);">
        <p style="margin: 0; color: var(--foreground); font-size: 1rem;">
          <strong style="color: var(--success);">Reponse rapide</strong><br>
          Nous repondons a toutes les demandes sous 24h ouvrees.
        </p>
      </div>
    </div>
    
    <div class="da-contact__form">
      {%- form 'contact', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div style="padding: 1.5rem; background: var(--success-10); border-radius: var(--radius); margin-bottom: 1.5rem; border: 1px solid var(--success);">
            <p style="margin: 0; color: var(--success); font-weight: 600;">Merci pour votre message ! Nous vous repondons sous 24h.</p>
          </div>
        {%- endif -%}
        
        {%- if form.errors -%}
          <div style="padding: 1.5rem; background: rgba(193, 122, 90, 0.1); border-radius: var(--radius); margin-bottom: 1.5rem; border: 1px solid var(--destructive);">
            <p style="margin: 0; color: var(--destructive); font-weight: 600;">{{ form.errors | default_errors }}</p>
          </div>
        {%- endif -%}
        
        <div class="field">
          <label for="contact-name">Votre nom *</label>
          <input type="text" id="contact-name" name="contact[name]" required placeholder="Jean Dupont">
        </div>
        
        <div class="field">
          <label for="contact-email">Votre email *</label>
          <input type="email" id="contact-email" name="contact[email]" required placeholder="jean@exemple.fr">
        </div>
        
        <div class="field">
          <label for="contact-phone">Telephone (optionnel)</label>
          <input type="tel" id="contact-phone" name="contact[phone]" placeholder="06 12 34 56 78">
        </div>
        
        <div class="field">
          <label for="contact-message">Votre message *</label>
          <textarea id="contact-message" name="contact[body]" required placeholder="Comment pouvons-nous vous aider ?"></textarea>
        </div>
        
        <button type="submit" class="da-btn da-btn-primary">
          Envoyer mon message
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Formulaire contact",
  "tag": "section",
  "class": "da-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Contactez-nous"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Une question sur nos coussins ? Notre equipe francaise est a votre ecoute du lundi au vendredi."
    }
  ],
  "presets": [
    {
      "name": "Formulaire contact"
    }
  ]
}
{% endschema %}
