{{- 'da-styles.css' | asset_url | stylesheet_tag -}}

<div class="da-cart-page" id="main-cart-items" data-id="{{ section.id }}">
  <div class="da-cart-page__inner">

    <div class="da-cart-page__header">
      <h1 class="da-cart-page__title">{{ 'sections.cart.title' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="da-cart-page__continue-link">
        {{ 'general.continue_shopping' | t }}
      </a>
    </div>

    {%- if cart == empty -%}

      <div class="da-cart-page__empty">
        <svg class="da-cart-page__empty-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <p class="da-cart-page__empty-text">{{ 'sections.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="da-btn da-btn-primary">
          Decouvrir nos coussins
        </a>
        {%- if shop.customer_accounts_enabled and customer == null -%}
          <p class="da-cart-page__login">
            {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
          </p>
        {%- endif -%}
      </div>

    {%- else -%}

      <form action="{{ routes.cart_url }}" class="da-cart-page__form" method="post" id="cart">
        <div class="da-cart-page__items js-contents">

          {%- for item in cart.items -%}
            <div class="da-cart-item" id="CartItem-{{ item.index | plus: 1 }}">

              <!-- Image -->
              <div class="da-cart-item__image">
                {%- if item.image -%}
                  <a href="{{ item.url }}" aria-hidden="true" tabindex="-1">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | default: item.product.title | escape }}"
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </a>
                {%- else -%}
                  <div class="da-cart-item__image-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  </div>
                {%- endif -%}
              </div>

              <!-- Infos produit -->
              <div class="da-cart-item__details">
                <a href="{{ item.url }}" class="da-cart-item__name">{{ item.product.title | escape }}</a>
                <div class="da-cart-item__unit-price">{{ item.original_price | money }}</div>
                {%- if item.product.has_only_default_variant == false -%}
                  {%- for option in item.options_with_values -%}
                    <p class="da-cart-item__option">{{ option.name }}: {{ option.value }}</p>
                  {%- endfor -%}
                {%- endif -%}
                {%- if item.original_price != item.final_price -%}
                  <span class="da-cart-item__discount">
                    {{ item.original_price | money }} → {{ item.final_price | money }}
                  </span>
                {%- endif -%}
              </div>

              <!-- Quantité -->
              <div class="da-cart-item__qty-wrap">
                <div class="da-qty">
                  <button
                    type="button"
                    class="da-qty__btn"
                    data-line="{{ item.index | plus: 1 }}"
                    data-action="decrease"
                    aria-label="Diminuer la quantite"
                    {% if item.quantity <= 1 %}disabled{% endif %}
                  >−</button>
                  <span class="da-qty__value" id="da-qty-{{ item.index | plus: 1 }}">{{ item.quantity }}</span>
                  <button
                    type="button"
                    class="da-qty__btn"
                    data-line="{{ item.index | plus: 1 }}"
                    data-action="increase"
                    aria-label="Augmenter la quantite"
                  >+</button>
                </div>
                <a
                  href="{{ item.url_to_remove }}"
                  class="da-cart-item__remove"
                  aria-label="Supprimer {{ item.product.title | escape }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  Supprimer
                </a>
              </div>

              <!-- Total ligne -->
              <div class="da-cart-item__line-total">
                {{ item.original_line_price | money }}
              </div>

            </div>
          {%- endfor -%}

        </div>
      </form>

    {%- endif -%}

    <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>

  </div>
</div>

<script>
(function() {
  document.querySelectorAll('.da-qty__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var line = parseInt(btn.dataset.line);
      var action = btn.dataset.action;
      var valueEl = document.getElementById('da-qty-' + line);
      var current = parseInt(valueEl.textContent);
      var newQty = action === 'increase' ? current + 1 : Math.max(0, current - 1);

      btn.disabled = true;

      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: newQty })
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
        location.reload();
      })
      .catch(function() { btn.disabled = false; });
    });
  });
})();
</script>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
