<section class="da-page-contact" itemscope itemtype="https://schema.org/ContactPage">
  <div class="da-page-contact__inner">
    
    <header class="da-page-contact__header">
      <h1 itemprop="name">Contactez-nous</h1>
      <p class="da-page-contact__intro">Notre equipe est a votre ecoute pour repondre a toutes vos questions</p>
    </header>

    <div class="da-page-contact__content">
      
      <div class="da-page-contact__info" itemprop="mainEntity" itemscope itemtype="https://schema.org/Organization">
        <meta itemprop="name" content="Douceur d'Assise">
        
        <h2>Nos coordonnees</h2>
        
        <div class="da-page-contact__details">
          <div class="da-page-contact__detail">
            <div class="da-page-contact__detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="da-page-contact__detail-content">
              <h3>Par telephone</h3>
              <p><a href="tel:+33186261020" itemprop="telephone">01 86 26 10 20</a></p>
              <p class="da-page-contact__detail-sub">Du lundi au vendredi, 9h - 18h</p>
            </div>
          </div>

          <div class="da-page-contact__detail">
            <div class="da-page-contact__detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div class="da-page-contact__detail-content">
              <h3>Par email</h3>
              <p><a href="mailto:contact@douceurdassise.fr" itemprop="email">contact@douceurdassise.fr</a></p>
              <p class="da-page-contact__detail-sub">Reponse sous 24h maximum</p>
            </div>
          </div>
        </div>

        <div class="da-page-contact__reassurance">
          <h3>Pourquoi nous contacter ?</h3>
          <ul>
            <li>Une question sur un produit</li>
            <li>Suivi de votre commande</li>
            <li>Demande de retour ou remboursement</li>
            <li>Conseil personnalise</li>
          </ul>
        </div>
      </div>

      <div class="da-page-contact__form-wrapper">
        <h2>Envoyez-nous un message</h2>
        
        {% form 'contact', class: 'da-page-contact__form' %}
          {% if form.posted_successfully? %}
            <div class="da-page-contact__success">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
              <p><strong>Merci pour votre message !</strong></p>
              <p>Nous vous repondrons sous 24h.</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="da-page-contact__error">
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {% endif %}

          <div class="da-page-contact__field">
            <label for="contact-name">Votre nom <span>*</span></label>
            <input type="text" id="contact-name" name="contact[name]" required placeholder="Jean Dupont">
          </div>

          <div class="da-page-contact__field">
            <label for="contact-email">Votre email <span>*</span></label>
            <input type="email" id="contact-email" name="contact[email]" required placeholder="jean.dupont@email.fr">
          </div>

          <div class="da-page-contact__field">
            <label for="contact-phone">Votre telephone</label>
            <input type="tel" id="contact-phone" name="contact[phone]" placeholder="06 12 34 56 78">
          </div>

          <div class="da-page-contact__field">
            <label for="contact-subject">Sujet <span>*</span></label>
            <select id="contact-subject" name="contact[subject]" required>
              <option value="">Choisissez un sujet</option>
              <option value="Question produit">Question sur un produit</option>
              <option value="Suivi commande">Suivi de commande</option>
              <option value="Retour">Demande de retour</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div class="da-page-contact__field da-page-contact__field--full">
            <label for="contact-message">Votre message <span>*</span></label>
            <textarea id="contact-message" name="contact[body]" rows="5" required placeholder="Decrivez votre demande..."></textarea>
          </div>

          <button type="submit" class="da-btn da-btn-primary da-page-contact__submit">
            Envoyer le message
          </button>
        {% endform %}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Page Contact",
  "tag": "section",
  "class": "section-contact"
}
{% endschema %}
