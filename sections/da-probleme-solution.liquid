<section class="da-problem-solution">
  <h2 class="da-problem-solution__heading">Vous reconnaissez-vous ?</h2>
  <div class="da-problem-solution__inner">

    <!-- Carte problèmes -->
    <div class="da-problem-solution__col da-problem-solution__col--problem">
      <h2 class="da-problem-solution__title da-problem-solution__title--problem">Vos problèmes</h2>
      <ul class="da-problem-solution__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'problem' -%}
            <li class="da-problem-solution__item" {{ block.shopify_attributes }}>
              <span class="da-problem-solution__icon da-problem-solution__icon--problem" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </span>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Carte solutions -->
    <div class="da-problem-solution__col da-problem-solution__col--solution">
      <h2 class="da-problem-solution__title da-problem-solution__title--solution">Nos solutions</h2>
      <ul class="da-problem-solution__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'solution' -%}
            <li class="da-problem-solution__item" {{ block.shopify_attributes }}>
              <span class="da-problem-solution__icon da-problem-solution__icon--solution" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </span>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

  </div>

  <div class="da-problem-solution__cta">
    <a href="{{ routes.collections_url }}" class="da-btn da-btn-primary">
      Découvrir la solution adaptée
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Probleme Solution DA",
  "blocks": [
    {
      "type": "problem",
      "name": "Probleme",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Problème",
          "default": "Douleurs au coccyx après être resté assis longtemps"
        }
      ]
    },
    {
      "type": "solution",
      "name": "Solution",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Solution",
          "default": "Soulagement immédiat des douleurs"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Probleme Solution DA",
      "blocks": [
        { "type": "problem", "settings": { "text": "Douleurs au coccyx après être resté assis longtemps" } },
        { "type": "problem", "settings": { "text": "Mal de dos en fin de journée" } },
        { "type": "problem", "settings": { "text": "Difficultés à trouver une position confortable" } },
        { "type": "problem", "settings": { "text": "Raideurs cervicales au réveil" } },
        { "type": "problem", "settings": { "text": "Inconfort pendant les longs trajets en voiture" } },
        { "type": "solution", "settings": { "text": "Soulagement immédiat des douleurs" } },
        { "type": "solution", "settings": { "text": "Mousse à mémoire de forme de qualité" } },
        { "type": "solution", "settings": { "text": "Design ergonomique étudié" } },
        { "type": "solution", "settings": { "text": "Housses lavables et hygiéniques" } },
        { "type": "solution", "settings": { "text": "Garantie satisfait ou remboursé 30 jours" } }
      ]
    }
  ]
}
{% endschema %}
