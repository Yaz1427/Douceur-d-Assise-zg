{% comment %}
  Douceur d'Assise - Page Produit
  Version custom sans dépendances CSS Horizon
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign compare_price = current_variant.compare_at_price -%}
{%- assign on_sale = false -%}
{%- if compare_price > current_variant.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}

<div class="da-product">
  <div class="da-product__inner">

    <!-- Galerie images -->
    <div class="da-product__gallery">
      {%- if product.images.size > 0 -%}
        <div class="da-product__main-image">
          <img
            id="da-main-img"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | default: product.title }}"
            width="800"
            height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
            loading="eager"
          >
        </div>
        {%- if product.images.size > 1 -%}
          <div class="da-product__thumbnails">
            {%- for image in product.images -%}
              <button
                class="da-product__thumb{% if forloop.first %} da-product__thumb--active{% endif %}"
                onclick="document.getElementById('da-main-img').src='{{ image | image_url: width: 800 }}'; this.parentNode.querySelectorAll('.da-product__thumb').forEach(b=>b.classList.remove('da-product__thumb--active')); this.classList.add('da-product__thumb--active');"
                aria-label="Image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | default: product.title }}"
                  width="120"
                  height="{{ 120 | divided_by: image.aspect_ratio | round }}"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="da-product__no-image">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          <p>Image à venir</p>
        </div>
      {%- endif -%}
    </div>

    <!-- Infos produit -->
    <div class="da-product__info">

      {%- if product.vendor != blank -%}
        <p class="da-product__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="da-product__title">{{ product.title }}</h1>

      <!-- Prix -->
      <div class="da-product__price-wrap">
        <span class="da-product__price">{{ current_variant.price | money_without_trailing_zeros }}</span>
        {%- if on_sale -%}
          <span class="da-product__price-old">{{ compare_price | money_without_trailing_zeros }}</span>
          <span class="da-product__badge-sale">Promo</span>
        {%- endif -%}
      </div>

      <!-- Badges de réassurance -->
      <div class="da-product__trust">
        <div class="da-product__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
          Livraison gratuite
        </div>
        <div class="da-product__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Satisfait ou remboursé 30 jours
        </div>
        <div class="da-product__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          SAV 100% français
        </div>
      </div>

      <!-- Formulaire ajout panier -->
      {%- form 'product', product, id: 'da-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          <div class="da-product__variants">
            {%- for option in product.options_with_values -%}
              <div class="da-product__option">
                <label class="da-product__option-label">{{ option.name }}</label>
                <div class="da-product__option-values">
                  {%- for value in option.values -%}
                    <label class="da-product__option-value">
                      <input
                        type="radio"
                        name="{{ option.name }}"
                        value="{{ value }}"
                        {% if option.selected_value == value %}checked{% endif %}
                      >
                      <span>{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="da-product__quantity">
          <label for="da-qty" class="da-product__qty-label">Quantité</label>
          <div class="da-product__qty-wrap">
            <button type="button" onclick="var i=document.getElementById('da-qty');i.value=Math.max(1,parseInt(i.value)-1)" aria-label="Diminuer">−</button>
            <input type="number" id="da-qty" name="quantity" value="1" min="1" aria-label="Quantité">
            <button type="button" onclick="var i=document.getElementById('da-qty');i.value=parseInt(i.value)+1" aria-label="Augmenter">+</button>
          </div>
        </div>

        <button type="submit" name="add" class="da-btn da-btn-primary da-product__add-to-cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          Ajouter au panier
        </button>
      {%- endform -%}

      <!-- Livraison -->
      <div class="da-product__delivery">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Livraison sous <strong>10-15 jours ouvrés</strong> · Suivi email inclus
      </div>

      <!-- Description -->
      {%- if product.description != blank -%}
        <div class="da-product__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page produit",
  "tag": "section",
  "class": "da-section-product"
}
{% endschema %}
