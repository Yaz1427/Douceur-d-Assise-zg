{% comment %}
  Douceur d'Assise - Featured Collection Section
  Grille de produits vedettes, version custom sans dépendances Horizon CSS
{% endcomment %}

{%- liquid
  assign display_collection = section.settings.collection | default: collections.all
  if display_collection == blank
    assign display_collection = collections.all
  endif
  assign products_limit = section.settings.products_to_show | default: 4
-%}

<div class="da-featured-collection">
  <div class="da-featured-collection__inner">

    {%- if section.settings.title != blank -%}
      <h2 class="da-featured-collection__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if display_collection.products.size > 0 -%}
      <div class="da-featured-collection__grid">
        {%- for product in display_collection.products limit: products_limit -%}
          {% render 'da-card-product', card_product: product %}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="da-featured-collection__cta">
          <a href="{{ display_collection.url }}" class="da-btn da-btn-secondary">
            Voir tous nos produits
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      <p class="da-featured-collection__empty">Aucun produit disponible pour le moment.</p>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Collection vedette",
  "tag": "section",
  "class": "da-section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Nos coussins les plus appréciés"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Nombre de produits"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Afficher le bouton \"Voir tout\"",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection vedette"
    }
  ]
}
{% endschema %}
