{{- 'da-styles.css' | asset_url | stylesheet_tag -}}

{%- assign cv = product.selected_or_first_available_variant -%}
{%- assign has_compare = false -%}
{%- if cv.compare_at_price > cv.price -%}
  {%- assign has_compare = true -%}
{%- endif -%}

<div class="pdp" id="pdp-{{ product.id }}">

  <!-- ╔══════════════════════════════╗
       ║  LIGNE DE FLOTTAISON MOBILE  ║
       ╚══════════════════════════════╝ -->
  <div class="pdp-top-row">

  <!-- 1. GALERIE -->
  <div class="pdp-gallery">
    <div class="pdp-gallery__main" id="pdp-slides">
      {%- for img in product.images limit: 6 -%}
        <div class="pdp-gallery__slide{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}">
          <img
            src="{{ img | image_url: width: 900 }}"
            alt="{{ img.alt | default: product.title | escape }}"
            width="900"
            height="{{ 900 | divided_by: img.aspect_ratio | round }}"
            {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
          >
        </div>
      {%- else -%}
        <div class="pdp-gallery__slide is-active">
          <div class="pdp-gallery__placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <p>Image a venir</p>
          </div>
        </div>
      {%- endfor -%}

      {%- if product.images.size > 1 -%}
        <button class="pdp-gallery__arrow pdp-gallery__arrow--prev" id="pdp-prev" aria-label="Image precedente">&#8249;</button>
        <button class="pdp-gallery__arrow pdp-gallery__arrow--next" id="pdp-next" aria-label="Image suivante">&#8250;</button>
      {%- endif -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="pdp-gallery__dots" id="pdp-dots">
        {%- for img in product.images limit: 6 -%}
          <button class="pdp-gallery__dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="Image {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
      <div class="pdp-gallery__thumbs" id="pdp-thumbs">
        {%- for img in product.images limit: 6 -%}
          <button class="pdp-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}">
            <img src="{{ img | image_url: width: 120 }}" alt="" width="60" height="60" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- 2. INFOS PRODUIT -->
  <div class="pdp-info">

    <!-- Titre -->
    <h1 class="pdp-info__title">{{ product.title }}</h1>

    <!-- Étoiles (si activé) -->
    {%- if section.settings.show_reviews -%}
      <div class="pdp-info__reviews">
        <span class="pdp-info__stars" aria-label="{{ section.settings.review_score }} etoiles sur 5">
          {%- for i in (1..5) -%}
            {%- if i <= section.settings.review_score -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </span>
        <span class="pdp-info__review-text">{{ section.settings.review_score }}/5 ({{ section.settings.review_count }} avis)</span>
      </div>
    {%- endif -%}

    <!-- Prix -->
    <div class="pdp-info__price-block">
      <div class="pdp-info__price-row">
        <span class="pdp-info__price" id="pdp-price">{{ cv.price | money_without_trailing_zeros }}</span>
        {%- if has_compare -%}
          <span class="pdp-info__price-old" id="pdp-compare">{{ cv.compare_at_price | money_without_trailing_zeros }}</span>
          <span class="pdp-info__price-badge">Economisez {{ cv.compare_at_price | minus: cv.price | money_without_trailing_zeros }}</span>
        {%- endif -%}
      </div>
    </div>

    <!-- 3 bullets de réassurance AVANT le bouton -->
    <ul class="pdp-info__trust-bullets">
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
        Livraison gratuite en France
      </li>
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Satisfait ou rembourse 30 jours
      </li>
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Garantie 2 ans
      </li>
    </ul>

    <!-- Variants (si applicable) -->
    {%- unless product.has_only_default_variant -%}
      <div class="pdp-info__variants" id="pdp-variants">
        {%- for option in product.options_with_values -%}
          <div class="pdp-info__option">
            <p class="pdp-info__option-label">{{ option.name }} :</p>
            <div class="pdp-info__option-btns">
              {%- for value in option.values -%}
                <button
                  type="button"
                  class="pdp-info__opt-btn{% if option.selected_value == value %} is-active{% endif %}"
                  data-opt="{{ forloop.parentloop.index0 }}"
                  data-val="{{ value | escape }}"
                >{{ value }}</button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endunless -%}

    <!-- BOUTON ATC principal -->
    <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" id="pdp-form">
      <input type="hidden" name="id" id="pdp-variant-id" value="{{ cv.id }}">
      <input type="hidden" name="quantity" id="pdp-qty-hidden" value="1">

      <div class="pdp-info__qty-row">
        <div class="pdp-info__qty">
          <button type="button" class="pdp-info__qty-btn" id="pdp-minus" aria-label="Moins">−</button>
          <span class="pdp-info__qty-val" id="pdp-qty-val">1</span>
          <button type="button" class="pdp-info__qty-btn" id="pdp-plus" aria-label="Plus">+</button>
        </div>
        <span class="pdp-info__qty-label">quantite</span>
      </div>

      <button
        type="submit"
        class="pdp-atc-btn"
        id="pdp-atc"
        {% if cv.available == false %}disabled{% endif %}
      >
        {%- if cv.available -%}
          Ajouter au panier
        {%- else -%}
          Produit temporairement indisponible
        {%- endif -%}
      </button>
    </form>

    <!-- Paiement sécurisé + icônes cartes -->
    <div class="pdp-info__secure">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Paiement 100% securise
    </div>
    <div class="pdp-info__cards">
      <span class="pdp-card pdp-card--visa">VISA</span>
      <span class="pdp-card pdp-card--mc">
        <span class="pdp-mc__left"></span><span class="pdp-mc__right"></span>
      </span>
      <span class="pdp-card pdp-card--cb">CB</span>
      <span class="pdp-card pdp-card--pp">Pay<em>Pal</em></span>
    </div>

  </div><!-- /.pdp-info -->
  </div><!-- /.pdp-top-row -->

  <!-- ╔══════════════════════════════╗
       ║  EN DESSOUS DE LA FLOTTAISON ║
       ╚══════════════════════════════╝ -->

  <!-- Bénéfices produit — détection automatique par handle -->
  {%- assign ph = product.handle -%}

  {%- if ph contains 'lombaire' or ph contains 'dos' -%}
    {%- assign benefits_title = 'Pourquoi ce coussin lombaire ?' -%}
    {%- assign b1 = 'Soutient naturellement le bas du dos, sans effort de votre part' -%}
    {%- assign b2 = 'Corrige votre posture assise — votre dos reste droit automatiquement' -%}
    {%- assign b3 = 'Soulage les douleurs lombaires et la tension musculaire du bas du dos' -%}
    {%- assign b4 = 'Ideal pour le bureau, la voiture et le canape — compatible avec tous les sieges' -%}

  {%- elsif ph contains 'jambe' or ph contains 'nuit' or ph contains 'sommeil' or ph contains 'paisible' -%}
    {%- assign benefits_title = 'Pourquoi ce coussin de nuit ?' -%}
    {%- assign b1 = 'Reduit les douleurs de hanche et de genou pendant la nuit' -%}
    {%- assign b2 = "Maintient l'alignement naturel de votre colonne vertebrale en position couchee" -%}
    {%- assign b3 = 'Vous vous reveillez repose, sans raideur ni tension dans les jambes' -%}
    {%- assign b4 = 'Doux et respirant pour un confort optimal toute la nuit' -%}

  {%- elsif ph contains 'auto' or ph contains 'voiture' or ph contains 'trajet' -%}
    {%- assign benefits_title = 'Pourquoi ce coussin auto ?' -%}
    {%- assign b1 = 'Finis les douleurs au coccyx et au dos pendant les longs trajets' -%}
    {%- assign b2 = 'Absorbe les vibrations de la route — votre dos ne souffre plus' -%}
    {%- assign b3 = 'Pose en quelques secondes, compatible avec tous les sieges auto' -%}
    {%- assign b4 = 'Arrivez a destination repose, sans douleur dans le dos' -%}

  {%- elsif ph contains 'cervical' or ph contains 'oreiller' or ph contains 'nuque' -%}
    {%- assign benefits_title = 'Pourquoi cet oreiller cervical ?' -%}
    {%- assign b1 = 'Soutient parfaitement votre nuque pendant toute la nuit' -%}
    {%- assign b2 = 'Reduit les douleurs cervicales et les raideurs au reveil' -%}
    {%- assign b3 = "Maintient l'alignement naturel tete-cou-dos pour un sommeil sain" -%}
    {%- assign b4 = 'Sommeil plus profond, reveil sans douleur ni raideur dans le cou' -%}

  {%- elsif ph contains 'pack' or ph contains 'integral' or ph contains 'premium' -%}
    {%- assign benefits_title = 'Pourquoi ce pack confort ?' -%}
    {%- assign b1 = 'Solution complete : soulage le coccyx, le dos et la nuque en meme temps' -%}
    {%- assign b2 = 'Couvre toutes les situations — assis, couche, en voiture' -%}
    {%- assign b3 = 'Economique par rapport aux achats separes de chaque coussin' -%}
    {%- assign b4 = 'Un seul achat pour retrouver le confort au quotidien, partout' -%}

  {%- else -%}
    {%- comment -%}Défaut : coussin coccyx{%- endcomment -%}
    {%- assign benefits_title = 'Pourquoi ce coussin ?' -%}
    {%- assign b1 = 'Soulage la douleur au coccyx des la premiere utilisation' -%}
    {%- assign b2 = 'Reduit la pression sur le coccyx et le bas du dos en position assise' -%}
    {%- assign b3 = 'Epouse parfaitement votre morphologie — mousse memoire de forme' -%}
    {%- assign b4 = 'Restez assis des heures sans souffrir, au bureau, en voiture ou a la maison' -%}
  {%- endif -%}

  <div class="pdp-benefits" id="pdp-benefits">
    <h2 class="pdp-section__title">{{ benefits_title }}</h2>
    <ul class="pdp-benefits__list">
      {%- for benefit in (1..4) -%}
        {%- assign bkey = 'b' | append: benefit -%}
        <li class="pdp-benefits__item">
          <span class="pdp-benefits__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </span>
          <span>
            {%- case benefit -%}
              {%- when 1 -%}{{ b1 }}
              {%- when 2 -%}{{ b2 }}
              {%- when 3 -%}{{ b3 }}
              {%- when 4 -%}{{ b4 }}
            {%- endcase -%}
          </span>
        </li>
      {%- endfor -%}
    </ul>
  </div>

  <!-- Description produit — injectee via handle pour chaque produit -->
  {%- assign pdesc_html = '' -%}

  {%- if ph contains 'coccyx' or ph contains 'classique' -%}
    {%- capture pdesc_html -%}
<p>Vous passez des heures assis et votre coccyx ou vos fesses vous font souffrir ? Ce coussin a ete concu precisement pour ca. Sa forme en U soulage la pression sur les zones sensibles et vous permet de rester assis sans douleur.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Moins de pression sur le coccyx et les ischions des les premieres minutes</li>
  <li>Une assise plus stable, sans glisser sur la chaise</li>
  <li>Un confort durable, que vous soyez devant la TV, a table ou en voiture</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Mousse a memoire de forme haute densite — s'adapte a votre morphologie</li>
  <li>Decoupe en U a l'avant — evacue la pression du coccyx et des ischions</li>
  <li>Housse en velours douce et respirante, lavable en machine</li>
  <li>Dimensions : environ 44 x 35 x 7 cm — compatible la plupart des chaises</li>
  <li>Antiderapant integre sous le coussin</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Posez le coussin sur votre chaise, la decoupe en U vers l'avant. Asseyez-vous normalement. C'est tout. Pas de reglage, pas de montage.</p>
<h3>Entretien</h3>
<p>Retirez la housse et lavez-la en machine a 30 degres. La mousse se nettoie avec un chiffon humide. Sechage a l'air libre.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'lombaire' or ph contains 'dos' -%}
    {%- capture pdesc_html -%}
<p>Le bas du dos qui tire apres quelques heures de bureau ou de television, c'est souvent un probleme de soutien. Ce coussin lombaire comble le vide entre votre dos et votre dossier, et maintient votre colonne dans sa position naturelle.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Le bas du dos soutenu sans effort de votre part</li>
  <li>Moins de fatigue en fin de journee</li>
  <li>Une posture meilleure, meme apres des heures de position assise</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Mousse a memoire de forme ergonomique — epouse la courbure naturelle de votre lombaire</li>
  <li>Elastique de fixation reglable — s'adapte a tous les dossiers de chaise</li>
  <li>Housse en velours respirant, lavable en machine</li>
  <li>Dimensions : environ 40 x 30 x 10 cm</li>
  <li>Leger — facilement transportable du bureau a la maison</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Fixez le coussin dans le bas de votre dossier de chaise grace a l'elastique. Asseyez-vous et appuyez votre dos contre lui. Vous sentirez immediatement le soutien.</p>
<h3>Entretien</h3>
<p>Housse lavable en machine a 30 degres. Sechage a plat, a l'air libre.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'jambe' or ph contains 'nuit' or ph contains 'sommeil' or ph contains 'paisible' -%}
    {%- capture pdesc_html -%}
<p>Les douleurs aux hanches, aux genoux ou au bas du dos pendant la nuit viennent souvent d'un mauvais alignement. Ce coussin se place entre les genoux et maintient votre bassin en position neutre tout au long de la nuit.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Moins de pression sur les hanches et les genoux</li>
  <li>Un alignement du bassin mieux respecte pendant le sommeil</li>
  <li>Des nuits plus reposantes, sans se reveiller a cause de la douleur</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Mousse a memoire de forme souple — confortable toute la nuit</li>
  <li>Forme anatomique concave — maintient les genoux en place sans glisser</li>
  <li>Sangle de maintien pour les bougeurs</li>
  <li>Housse en tissu doux et respirant, lavable en machine</li>
  <li>Dimensions : environ 25 x 20 x 15 cm</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Placez le coussin entre vos genoux lorsque vous dormez sur le cote. La forme en creux maintient les jambes en place naturellement.</p>
<h3>Entretien</h3>
<p>Housse lavable en machine a 30 degres. Sechage a l'air libre.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'auto' or ph contains 'voiture' or ph contains 'trajet' or ph contains 'rehausseur' -%}
    {%- capture pdesc_html -%}
<p>Un long trajet en voiture peut vite devenir penible quand on souffre du dos ou du coccyx. Ce coussin rehausseur rehausse legerement votre position et redistribue le poids pour que vous arriviez a destination sans etre epuise.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Moins de pression sur le bas du dos et le coccyx</li>
  <li>Une vision de la route legerement amelioree grace au rehaussement (3 a 5 cm)</li>
  <li>Moins de fatigue sur les longs trajets</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Mousse haute densite — ne s'ecrase pas sous le poids du corps</li>
  <li>Rehaussement de 3 a 5 cm — ameliore la posture au volant</li>
  <li>Antiderapant integre — ne bouge pas pendant la conduite</li>
  <li>Housse en tissu respirant, lavable en machine</li>
  <li>Dimensions : environ 40 x 35 x 5 cm — compatible avec la grande majorite des sieges auto</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Posez le coussin sur votre siege conducteur ou passager. Le cote antiderapant en dessous. Asseyez-vous et ajustez votre position de conduite normalement.</p>
<h3>Entretien</h3>
<p>Housse lavable en machine a 30 degres. Sechage a l'air libre.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'cervical' or ph contains 'oreiller' or ph contains 'nuque' -%}
    {%- capture pdesc_html -%}
<p>Vous vous reveillez avec des douleurs dans le cou ou les epaules ? L'oreiller plat ou trop epais ne soutient pas la nuque correctement. Cet oreiller cervical maintient votre tete dans l'axe de votre colonne vertebrale pendant toute la nuit.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>La nuque soutenue sans tension pendant le sommeil</li>
  <li>Moins de raideurs au lever</li>
  <li>Un sommeil plus profond, sans se retourner constamment</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Mousse a memoire de forme — s'adapte a la forme de votre cou et de vos epaules</li>
  <li>Deux hauteurs integrees : cote plus haut pour les dormeurs sur le cote, cote plus bas pour ceux sur le dos</li>
  <li>Housse en tissu bambou doux et respirant, lavable en machine</li>
  <li>Dimensions : environ 60 x 40 x 10/12 cm</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Choisissez la hauteur adaptee a votre position de sommeil habituelle. Le cote haut pour dormir sur le cote, le cote bas pour dormir sur le dos.</p>
<h3>Entretien</h3>
<p>Housse lavable en machine a 30 degres. Ne pas mettre la mousse en machine.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'pack' and ph contains 'duo' -%}
    {%- capture pdesc_html -%}
<p>Le Pack Duo reunit nos deux coussins les plus vendus : le coussin coccyx et le coussin lombaire. Une solution complete pour ceux qui souffrent a la fois du bas du dos et du coccyx, au bureau comme a la maison.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Le coccyx et le bas du dos soutenus en meme temps</li>
  <li>Une posture globalement amelioree des les premieres utilisations</li>
  <li>Moins de fatigue en fin de journee</li>
</ul>
<h3>Contenu du pack</h3>
<ul>
  <li><strong>Coussin Coccyx</strong> — mousse memoire de forme, decoupe en U, housse velours lavable</li>
  <li><strong>Coussin Lombaire</strong> — mousse ergonomique, elastique de fixation reglable, housse velours lavable</li>
</ul>
<h3>Pourquoi un pack plutot que deux achats separement ?</h3>
<p>Les deux coussins sont complementaires : l'un soutient ce qui touche le siege (coccyx et ischions), l'autre soutient le dos contre le dossier. Ensemble, ils corrigent l'ensemble de la posture assise.</p>
<h3>Entretien</h3>
<p>Les deux housses sont lavables en machine a 30 degres. Sechage a l'air libre.</p>
    {%- endcapture -%}

  {%- elsif ph contains 'pack' -%}
    {%- capture pdesc_html -%}
<p>Le Pack Premium combine dans une seule piece le soutien du coccyx et du lombaire. Une solution tout-en-un pour ceux qui veulent simplifier : un seul coussin a poser, deux problemes resolus.</p>
<h3>Ce que vous allez ressentir</h3>
<ul>
  <li>Le coccyx et le bas du dos soutenus simultanement</li>
  <li>Une posture complete corrigee en une seule action</li>
  <li>Ideal pour les chaises sans bon dossier (chaises de salle a manger, fauteuils plats)</li>
</ul>
<h3>Caracteristiques</h3>
<ul>
  <li>Coussin monobloc — assise + soutien lombaire integres</li>
  <li>Mousse a memoire de forme haute densite</li>
  <li>Decoupe en U a l'avant pour soulager le coccyx</li>
  <li>Dossier courbe integre pour le lombaire</li>
  <li>Housse en velours respirant, lavable en machine</li>
</ul>
<h3>Utilisation recommandee</h3>
<p>Posez le coussin sur votre chaise. Asseyez-vous normalement en appuyant le dos contre la partie dossier. Tout est en place en quelques secondes.</p>
<h3>Entretien</h3>
<p>Housse lavable en machine a 30 degres. Sechage a l'air libre.</p>
    {%- endcapture -%}

  {%- endif -%}

  {%- assign desc_body = '' -%}
  {%- if pdesc_html != blank -%}
    {%- assign desc_body = pdesc_html -%}
  {%- elsif product.description != blank -%}
    {%- assign desc_body = product.description -%}
  {%- endif -%}

  {%- if desc_body != blank -%}
    <div class="pdp-desc" id="pdp-desc">
      <h2 class="pdp-section__title">Caracteristiques</h2>
      <div class="pdp-desc__inner">
        <div class="pdp-desc__body rte">{{ desc_body }}</div>
        <div class="pdp-desc__aside">
          {%- if section.settings.desc_image != blank -%}
            <img
              src="{{ section.settings.desc_image | image_url: width: 700 }}"
              alt="{{ section.settings.desc_image.alt | default: product.title | escape }}"
              width="700"
              loading="lazy"
              class="pdp-desc__aside-img"
            >
          {%- else -%}
            <div class="pdp-img-placeholder">
              {{ 'product-2' | placeholder_svg_tag: 'pdp-img-placeholder__svg' }}
              <span class="pdp-img-placeholder__label">Image description</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Grille d'images produit — choisies dans le customizer -->
  <div class="pdp-img-strip">
    {%- assign strip_keys = 'strip_img_1,strip_img_2,strip_img_3,strip_img_4' | split: ',' -%}
    {%- assign placeholder_names = 'product-3,product-4,product-5,product-6' | split: ',' -%}
    {%- for key in strip_keys -%}
      {%- assign ph_name = placeholder_names[forloop.index0] -%}
      <div class="pdp-img-strip__item">
        {%- if section.settings[key] != blank -%}
          <img
            src="{{ section.settings[key] | image_url: width: 700 }}"
            alt="{{ section.settings[key].alt | default: product.title | escape }}"
            width="700"
            loading="lazy"
          >
        {%- else -%}
          <div class="pdp-img-placeholder pdp-img-placeholder--strip">
            {{ ph_name | placeholder_svg_tag: 'pdp-img-placeholder__svg' }}
            <span class="pdp-img-placeholder__label">Photo {{ forloop.index }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <!-- Mini FAQ — adaptée par type de produit -->
  {%- assign faq_livraison_q = 'Combien de temps pour recevoir ma commande ?' -%}
  {%- assign faq_livraison_a = '<p>Votre commande est expediee sous 48h et livree chez vous en 10 a 15 jours ouvres. La livraison est gratuite partout en France. Vous recevez un numero de suivi par email.</p>' -%}
  {%- assign faq_retour_q = 'Et si le produit ne me convient pas ?' -%}
  {%- assign faq_retour_a = '<p>Vous avez 30 jours pour changer de decision. Si le produit ne vous convient pas, renvoyez-le et nous vous remboursons integralement. Sans condition.</p>' -%}

  {%- if ph contains 'lombaire' or ph contains 'dos' -%}
    {%- assign faq1_q = 'Est-ce que ce coussin convient pour le bureau ?' -%}
    {%- assign faq1_a = '<p>Oui, il est concu pour les longues heures de bureau. Il se fixe sur le dossier de votre chaise et soutient le bas du dos en maintenant votre colonne dans sa courbure naturelle.</p>' -%}
    {%- assign faq2_q = faq_livraison_q -%}
    {%- assign faq2_a = faq_livraison_a -%}
    {%- assign faq3_q = faq_retour_q -%}
    {%- assign faq3_a = faq_retour_a -%}

  {%- elsif ph contains 'jambe' or ph contains 'nuit' or ph contains 'sommeil' or ph contains 'paisible' -%}
    {%- assign faq1_q = 'Comment utilise-t-on ce coussin ?' -%}
    {%- assign faq1_a = '<p>Il se place entre vos genoux lorsque vous dormez sur le cote. Il maintient vos hanches alignees et reduit la pression sur les articulations pour un sommeil sans interruption.</p>' -%}
    {%- assign faq2_q = faq_livraison_q -%}
    {%- assign faq2_a = faq_livraison_a -%}
    {%- assign faq3_q = faq_retour_q -%}
    {%- assign faq3_a = faq_retour_a -%}

  {%- elsif ph contains 'auto' or ph contains 'voiture' or ph contains 'trajet' -%}
    {%- assign faq1_q = 'Ce coussin reste-t-il en place pendant la conduite ?' -%}
    {%- assign faq1_a = '<p>Oui, il est equipe de sangles de fixation qui le maintiennent sur le siege, meme sur les longs trajets. Il ne glisse pas.</p>' -%}
    {%- assign faq2_q = faq_livraison_q -%}
    {%- assign faq2_a = faq_livraison_a -%}
    {%- assign faq3_q = faq_retour_q -%}
    {%- assign faq3_a = faq_retour_a -%}

  {%- elsif ph contains 'cervical' or ph contains 'oreiller' or ph contains 'nuque' -%}
    {%- assign faq1_q = 'Quelle position de sommeil convient le mieux ?' -%}
    {%- assign faq1_a = '<p>Cet oreiller convient aux personnes qui dorment sur le dos ou sur le cote. Sa forme epouse la courbure naturelle de la nuque dans les deux positions pour un soutien optimal.</p>' -%}
    {%- assign faq2_q = faq_livraison_q -%}
    {%- assign faq2_a = faq_livraison_a -%}
    {%- assign faq3_q = faq_retour_q -%}
    {%- assign faq3_a = faq_retour_a -%}

  {%- elsif ph contains 'pack' or ph contains 'integral' or ph contains 'premium' -%}
    {%- assign faq1_q = 'Quels produits sont inclus dans ce pack ?' -%}
    {%- assign faq1_a = '<p>Ce pack reunit notre coussin coccyx, notre soutien lombaire et notre oreiller cervical. Ensemble, ils couvrent toutes les situations : assis, en voiture et la nuit.</p>' -%}
    {%- assign faq2_q = faq_livraison_q -%}
    {%- assign faq2_a = faq_livraison_a -%}
    {%- assign faq3_q = faq_retour_q -%}
    {%- assign faq3_a = faq_retour_a -%}

  {%- else -%}
    {%- assign faq1_q = faq_livraison_q -%}
    {%- assign faq1_a = faq_livraison_a -%}
    {%- assign faq2_q = faq_retour_q -%}
    {%- assign faq2_a = faq_retour_a -%}
    {%- assign faq3_q = 'Comment je lave la housse ?' -%}
    {%- assign faq3_a = '<p>La housse se retire facilement grace a la fermeture eclair. Lavage en machine a 30 degres, sechage a plat. Le coussin lui-meme se nettoie avec un chiffon humide.</p>' -%}
  {%- endif -%}

  <div class="pdp-faq" id="pdp-faq">
    <div class="pdp-faq-wrap">
      <h2 class="pdp-section__title">Questions frequentes</h2>
      {%- assign faqs = faq1_q | append: '|||' | append: faq1_a | append: '^^^' | append: faq2_q | append: '|||' | append: faq2_a | append: '^^^' | append: faq3_q | append: '|||' | append: faq3_a -%}
      {%- assign faq_items = faqs | split: '^^^' -%}
      {%- for item in faq_items -%}
        {%- assign parts = item | split: '|||' -%}
        {%- if parts.size == 2 -%}
          <details class="pdp-faq__item">
            <summary class="pdp-faq__q">
              {{ parts[0] }}
              <svg class="pdp-faq__chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="pdp-faq__a">{{ parts[1] }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- CTA répété en bas + téléphone -->
  <div class="pdp-footer-cta">
    <button type="button" class="pdp-atc-btn" id="pdp-atc-bottom" {% if cv.available == false %}disabled{% endif %}>
      Ajouter au panier
    </button>
    {%- if section.settings.show_phone -%}
      <p class="pdp-footer-cta__phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Besoin d'aide ? Appelez-nous au
        <a href="tel:{{ section.settings.phone | default: '0186261020' }}">
          {{ section.settings.phone | default: '01 86 26 10 20' }}
        </a>
      </p>
    {%- endif -%}
  </div>

</div><!-- /.pdp -->

<!-- STICKY ATC (mobile, apparait apres scroll) -->
<div class="pdp-sticky" id="pdp-sticky" aria-hidden="true">
  <div class="pdp-sticky__inner">
    <div>
      <span class="pdp-sticky__name">{{ product.title | truncate: 28 }}</span>
      <span class="pdp-sticky__price" id="pdp-sticky-price">{{ cv.price | money_without_trailing_zeros }}</span>
    </div>
    <button type="button" class="pdp-sticky__btn" id="pdp-sticky-btn">Ajouter au panier</button>
  </div>
</div>

<!-- POPUP AJOUT PANIER -->
<div class="atc-popup" id="atc-popup" aria-live="polite" aria-hidden="true">
  <div class="atc-popup__inner">
    <div class="atc-popup__header">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      <span>Ajouté au panier !</span>
      <button class="atc-popup__close" id="atc-popup-close" aria-label="Fermer">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div class="atc-popup__product">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="80" height="80" class="atc-popup__img">
      {%- endif -%}
      <div class="atc-popup__info">
        <p class="atc-popup__name">{{ product.title | truncate: 50 }}</p>
        <p class="atc-popup__price" id="atc-popup-price">{{ cv.price | money_without_trailing_zeros }}</p>
      </div>
    </div>
    <div class="atc-popup__actions">
      <button class="atc-popup__btn atc-popup__btn--secondary" id="atc-popup-continue">Continuer mes achats</button>
      <a href="/cart" class="atc-popup__btn atc-popup__btn--primary">Voir mon panier</a>
    </div>
  </div>
</div>

<script>
(function() {

  /* ── Variante par défaut ──────────────── */
  var variants = {{ product.variants | json }};
  var selectedOpts = {};
  {%- for opt in product.options_with_values -%}
  selectedOpts[{{ forloop.index0 }}] = {{ opt.selected_value | json }};
  {%- endfor -%}

  var variantInput = document.getElementById('pdp-variant-id');
  var priceEl = document.getElementById('pdp-price');
  var compareEl = document.getElementById('pdp-compare');
  var atcBtn = document.getElementById('pdp-atc');
  var atcBottom = document.getElementById('pdp-atc-bottom');
  var stickyPrice = document.getElementById('pdp-sticky-price');
  var qtyVal = document.getElementById('pdp-qty-val');
  var qtyHidden = document.getElementById('pdp-qty-hidden');
  var stickyBar = document.getElementById('pdp-sticky');
  var form = document.getElementById('pdp-form');

  function money(cents) {
    var eur = Math.round(cents) / 100;
    return eur % 1 === 0
      ? eur.toLocaleString('fr-FR') + '\u00a0€'
      : eur.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) + '\u00a0€';
  }

  function findVariant() {
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      var ok = true;
      for (var o = 0; o < Object.keys(selectedOpts).length; o++) {
        if (v['option' + (o + 1)] !== selectedOpts[o]) { ok = false; break; }
      }
      if (ok) return v;
    }
    return null;
  }

  function updateUI(v) {
    if (!v) return;
    if (variantInput) variantInput.value = v.id;
    if (priceEl) priceEl.textContent = money(v.price);
    if (stickyPrice) stickyPrice.textContent = money(v.price);
    if (compareEl) compareEl.style.display = (v.compare_at_price > v.price) ? '' : 'none';
    var avail = v.available;
    var txt = avail ? 'Ajouter au panier' : 'Produit temporairement indisponible';
    if (atcBtn) { atcBtn.disabled = !avail; atcBtn.textContent = txt; }
    if (atcBottom) { atcBottom.disabled = !avail; atcBottom.textContent = txt; }
  }

  /* ── Sélecteur variants ───────────────── */
  document.querySelectorAll('.pdp-info__opt-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var opt = parseInt(btn.dataset.opt);
      btn.closest('.pdp-info__option-btns').querySelectorAll('.pdp-info__opt-btn').forEach(function(b) {
        b.classList.remove('is-active');
      });
      btn.classList.add('is-active');
      selectedOpts[opt] = btn.dataset.val;
      updateUI(findVariant());
    });
  });

  /* ── Quantité ─────────────────────────── */
  var qty = 1;
  document.getElementById('pdp-minus') && document.getElementById('pdp-minus').addEventListener('click', function() {
    if (qty > 1) { qty--; if (qtyVal) qtyVal.textContent = qty; if (qtyHidden) qtyHidden.value = qty; }
  });
  document.getElementById('pdp-plus') && document.getElementById('pdp-plus').addEventListener('click', function() {
    if (qty < 10) { qty++; if (qtyVal) qtyVal.textContent = qty; if (qtyHidden) qtyHidden.value = qty; }
  });

  /* ── Bouton bas de page ───────────────── */
  if (atcBottom) {
    atcBottom.addEventListener('click', function() {
      if (form) form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
    });
  }

  /* ── Popup panier ────────────────────── */
  var popup = document.getElementById('atc-popup');
  var popupClose = document.getElementById('atc-popup-close');
  var popupContinue = document.getElementById('atc-popup-continue');
  var popupTimer = null;

  function updateBadge(count) {
    var badge = document.getElementById('da-cart-badge');
    if (!badge) return;
    badge.textContent = count;
    badge.style.display = count > 0 ? '' : 'none';
    badge.classList.remove('is-updating');
    void badge.offsetWidth;
    badge.classList.add('is-updating');
  }

  function openPopup() {
    if (!popup) return;
    popup.setAttribute('aria-hidden', 'false');
    popup.classList.add('is-open');
    if (popupTimer) clearTimeout(popupTimer);
    popupTimer = setTimeout(closePopup, 5000);
  }

  function closePopup() {
    if (!popup) return;
    popup.classList.remove('is-open');
    popup.setAttribute('aria-hidden', 'true');
  }

  if (popupClose) popupClose.addEventListener('click', closePopup);
  if (popupContinue) popupContinue.addEventListener('click', closePopup);

  /* ── ATC AJAX ─────────────────────────── */
  function doAddToCart() {
    if (!variantInput || !variantInput.value) return;
    var btns = [atcBtn, document.getElementById('pdp-sticky-btn'), document.getElementById('pdp-atc-bottom')];
    btns.forEach(function(b) { if (b) { b.disabled = true; b.textContent = 'Ajout en cours...'; } });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantInput.value), quantity: qty })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('add failed');
      return r.json();
    })
    .then(function() {
      /* Recuperer le panier mis a jour */
      return fetch('/cart.js').then(function(r) { return r.json(); });
    })
    .then(function(cart) {
      var n = cart.item_count || 0;
      /* Mise a jour badge */
      updateBadge(n);
      /* Event global */
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      /* Afficher popup */
      openPopup();
      /* Restaurer boutons */
      btns.forEach(function(b) { if (b) { b.disabled = false; b.textContent = 'Ajouter au panier'; } });
    })
    .catch(function() {
      btns.forEach(function(b) { if (b) { b.disabled = false; b.textContent = 'Ajouter au panier'; } });
    });
  }

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      doAddToCart();
    });
  }

  /* ── Galerie ──────────────────────────── */
  var slidesEl = document.getElementById('pdp-slides');
  var slides = slidesEl ? slidesEl.querySelectorAll('.pdp-gallery__slide') : [];
  var dots = document.querySelectorAll('.pdp-gallery__dot');
  var thumbs = document.querySelectorAll('.pdp-gallery__thumb');
  var cur = 0;

  function goTo(n) {
    if (!slides.length) return;
    n = ((n % slides.length) + slides.length) % slides.length;
    slides[cur].classList.remove('is-active');
    if (dots[cur]) dots[cur].classList.remove('is-active');
    if (thumbs[cur]) thumbs[cur].classList.remove('is-active');
    cur = n;
    slides[cur].classList.add('is-active');
    if (dots[cur]) dots[cur].classList.add('is-active');
    if (thumbs[cur]) thumbs[cur].classList.add('is-active');
  }

  var prevBtn = document.getElementById('pdp-prev');
  var nextBtn = document.getElementById('pdp-next');
  if (prevBtn) prevBtn.addEventListener('click', function() { goTo(cur - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goTo(cur + 1); });

  dots.forEach(function(d) { d.addEventListener('click', function() { goTo(parseInt(d.dataset.idx)); }); });
  thumbs.forEach(function(t) { t.addEventListener('click', function() { goTo(parseInt(t.dataset.idx)); }); });

  /* Swipe touch */
  if (slidesEl) {
    var tx = 0;
    slidesEl.addEventListener('touchstart', function(e) { tx = e.changedTouches[0].clientX; }, { passive: true });
    slidesEl.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - tx;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? cur + 1 : cur - 1);
    });
  }

  /* ── Sticky bar ───────────────────────── */
  if (stickyBar && atcBtn) {
    window.addEventListener('scroll', function() {
      var rect = atcBtn.getBoundingClientRect();
      if (rect.bottom < 0) {
        stickyBar.classList.add('is-visible');
        stickyBar.setAttribute('aria-hidden', 'false');
      } else {
        stickyBar.classList.remove('is-visible');
        stickyBar.setAttribute('aria-hidden', 'true');
      }
    }, { passive: true });
  }

  var stickyBtn = document.getElementById('pdp-sticky-btn');
  if (stickyBtn && form) {
    stickyBtn.addEventListener('click', function() {
      form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
    });
  }

})();
</script>

