    },
    {
      "type": "image_picker",
      "id": "strip_img_1",
      "label": "Photo 1"
    },
    {
      "type": "image_picker",
      "id": "strip_img_2",
      "label": "Photo 2"
    },
    {
      "type": "image_picker",
      "id": "strip_img_3",
      "label": "Photo 3"
    },
    {
      "type": "image_picker",
      "id": "strip_img_4",
      "label": "Photo 4"
    }
  ],
  "blocks": [
    {
