    },
    {
      "type": "image_picker",
      "id": "strip_img_2",
      "label": "Photo 2 (ex. en voiture)"
    },
    {
      "type": "text",
      "id": "strip_caption_2",
      "label": "Legende photo 2"
    },
    {
      "type": "image_picker",
      "id": "strip_img_3",
      "label": "Photo 3 (ex. sur le canape)"
    },
    {
      "type": "text",
      "id": "strip_caption_3",
      "label": "Legende photo 3"
    },
    {
      "type": "image_picker",
      "id": "strip_img_4",
      "label": "Photo 4 (ex. detail produit)"
