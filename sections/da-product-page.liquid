        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fiche produit",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Soulage les douleurs au coccyx des la premiere utilisation" } },
        { "type": "benefit", "settings": { "text": "Votre dos reste naturellement droit, sans effort" } },
        { "type": "benefit", "settings": { "text": "S'adapte parfaitement a votre corps (mousse memoire de forme)" } },
        { "type": "benefit", "settings": { "text": "Vous restez assis des heures sans douleur" } },
        { "type": "faq", "settings": { "question": "Combien de temps pour recevoir ma commande ?", "answer": "<p>Votre coussin est expedie sous 48h et livre chez vous en 10-15 jours ouvres. La livraison est gratuite partout en France. Vous recevez un numero de suivi par email.</p>" } },
        { "type": "faq", "settings": { "question": "Et si le coussin ne me convient pas ?", "answer": "<p>Vous avez 30 jours pour changer d'avis. Si le coussin ne vous convient pas, renvoyez-le et nous vous remboursons integralement. Sans condition.</p>" } },
        { "type": "faq", "settings": { "question": "Comment je lave la housse ?", "answer": "<p>La housse se retire facilement grace a la fermeture eclair. Lavage en machine a 30 degres, sechage a l'air libre.</p>" } }
      ]
    }
  ]
}
