{{- 'da-styles.css' | asset_url | stylesheet_tag -}}

<div class="da-customer-page">
  <div class="da-customer-page__inner">

    <div class="da-customer-page__header">
      <h1 class="da-customer-page__title">Mon compte</h1>
      <p class="da-customer-page__subtitle">Connectez-vous pour suivre vos commandes et gerer vos informations.</p>
    </div>

    <div class="da-customer-page__forms">

      <!-- Connexion -->
      <div class="da-customer-card" id="da-login-form">
        <h2 class="da-customer-card__title">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
          Se connecter
        </h2>

        {%- form 'customer_login', id: 'da-form-login' -%}
          {%- if form.errors -%}
            <div class="da-customer-page__errors" role="alert">
              {%- for error in form.errors -%}
                <p>{{ form.errors.messages[error] }}</p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="da-field">
            <label class="da-field__label" for="da-login-email">Adresse email</label>
            <input
              class="da-field__input"
              type="email"
              name="customer[email]"
              id="da-login-email"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              required
              placeholder="votre@email.fr"
            >
          </div>

          <div class="da-field">
            <div class="da-field__label-row">
              <label class="da-field__label" for="da-login-password">Mot de passe</label>
              <a href="{{ routes.account_recover_url }}" class="da-field__link-small">Mot de passe oublie ?</a>
            </div>
            <input
              class="da-field__input"
              type="password"
              name="customer[password]"
              id="da-login-password"
              autocomplete="current-password"
              required
              placeholder="••••••••"
            >
          </div>

          <button type="submit" class="da-btn da-btn-primary da-btn--full">
            Se connecter
          </button>
        {%- endform -%}
      </div>

      <!-- Creer un compte -->
      <div class="da-customer-card">
        <h2 class="da-customer-card__title">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
          Creer un compte
        </h2>
        <p class="da-customer-card__desc">Creez un compte pour suivre vos commandes facilement et gerer vos informations.</p>

        {%- form 'create_customer', id: 'da-form-register' -%}
          {%- if form.errors -%}
            <div class="da-customer-page__errors" role="alert">
              {%- for error in form.errors -%}
                <p>{{ form.errors.messages[error] }}</p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="da-field">
            <label class="da-field__label" for="da-reg-firstname">Prenom</label>
            <input class="da-field__input" type="text" name="customer[first_name]" id="da-reg-firstname" autocomplete="given-name" placeholder="Jean">
          </div>

          <div class="da-field">
            <label class="da-field__label" for="da-reg-lastname">Nom</label>
            <input class="da-field__input" type="text" name="customer[last_name]" id="da-reg-lastname" autocomplete="family-name" placeholder="Dupont">
          </div>

          <div class="da-field">
            <label class="da-field__label" for="da-reg-email">Adresse email</label>
            <input class="da-field__input" type="email" name="customer[email]" id="da-reg-email" autocomplete="email" required placeholder="votre@email.fr">
          </div>

          <div class="da-field">
            <label class="da-field__label" for="da-reg-password">Mot de passe</label>
            <input class="da-field__input" type="password" name="customer[password]" id="da-reg-password" autocomplete="new-password" required placeholder="Minimum 5 caracteres">
          </div>

          <button type="submit" class="da-btn da-btn-primary da-btn--full">
            Creer mon compte
          </button>
        {%- endform -%}
      </div>

    </div><!-- /.da-customer-page__forms -->

    <!-- Réassurance -->
    <div class="da-customer-page__trust">
      <span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Vos donnees sont protegees
      </span>
      <span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Gratuit et sans engagement
      </span>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Connexion compte",
  "tag": "section"
}
{% endschema %}
