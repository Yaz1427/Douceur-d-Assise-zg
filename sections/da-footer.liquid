{% comment %}
  Douceur d'Assise - Footer Section
  Pied de page avec contact, liens, et badges paiement securise
{% endcomment %}

<footer class="da-footer">
  <div class="da-footer__inner">
    <!-- Contact -->
    <div class="da-footer__col">
      <h3>Contact</h3>
      <ul>
        <li>
          <a href="mailto:{{ section.settings.email | default: 'contact@douceurdassise.fr' }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            {{ section.settings.email | default: 'contact@douceurdassise.fr' }}
          </a>
        </li>
        <li>
          <a href="tel:{{ section.settings.phone | default: '0186261020' }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {{ section.settings.phone | default: '01 86 26 10 20' }}
          </a>
        </li>
        <li class="da-footer__address">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{{ section.settings.address | default: 'Paris, France' }}</span>
        </li>
      </ul>
    </div>

    <!-- Informations -->
    <div class="da-footer__col">
      <h3>Informations</h3>
      <ul>
        <li><a href="/pages/a-propos">A propos</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/pages/livraison">Livraison</a></li>
        <li><a href="/pages/cgv">CGV</a></li>
        <li><a href="/pages/mentions-legales">Mentions legales</a></li>
      </ul>
    </div>

    <!-- Boutique -->
    <div class="da-footer__col">
      <h3>Boutique</h3>
      <ul>
        <li><a href="/collections/all">Tous les produits</a></li>
        <li><a href="/collections/coussins-coccyx">Coussins coccyx</a></li>
        <li><a href="/collections/coussins-lombaires">Coussins lombaires</a></li>
        <li><a href="/pages/contact">Nous contacter</a></li>
      </ul>
    </div>

    <!-- Paiement -->
    <div class="da-footer__col">
      <h3>Paiement securise</h3>
      <div class="da-footer__payment-badges">
        <span class="da-footer__payment-badge">CB</span>
        <span class="da-footer__payment-badge">Visa</span>
        <span class="da-footer__payment-badge">Mastercard</span>
        <span class="da-footer__payment-badge">PayPal</span>
      </div>
      <div class="da-footer__secure">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Paiement 100% securise
      </div>
    </div>
  </div>

  <div class="da-footer__bottom">
    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits reserves.
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page DA",
  "settings": [
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "contact@douceurdassise.fr"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telephone",
      "default": "01 86 26 10 20"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Adresse",
      "default": "Paris, France"
    }
  ]
}
{% endschema %}
