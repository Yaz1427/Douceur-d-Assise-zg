{% comment %}
  Douceur d'Assise - Footer Section
  Pied de page complet 4 colonnes avec liens, badges paiement et mentions legales
{% endcomment %}

<footer class="da-footer">
  <div class="da-footer__inner">

    <!-- Colonne 1 : Marque -->
    <div class="da-footer__col da-footer__col--brand">
      <div class="da-footer__brand-logo">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 140 }}"
            alt="{{ shop.name }}"
            width="140"
            loading="lazy"
          >
        {%- else -%}
          <span class="da-footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
      </div>
      <p class="da-footer__tagline">Le confort retrouvé, simplement.</p>
      <p class="da-footer__flag">🇫🇷 Entreprise française</p>
      <div class="da-footer__contact-quick">
        <a href="mailto:{{ section.settings.email | default: 'contact@douceurdassise.fr' }}" class="da-footer__contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {{ section.settings.email | default: 'contact@douceurdassise.fr' }}
        </a>
        <a href="tel:{{ section.settings.phone | default: '0186261020' | remove: ' ' }}" class="da-footer__contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ section.settings.phone | default: '01 86 26 10 20' }}
        </a>
        <span class="da-footer__contact-link da-footer__address">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          {{ section.settings.address | default: 'Paris, France' }}
        </span>
      </div>
    </div>

    <!-- Colonne 2 : Boutique -->
    <div class="da-footer__col">
      <h3 class="da-footer__col-title">Boutique</h3>
      <ul class="da-footer__links">
        <li><a href="/collections/all">Nos coussins</a></li>
        <li><a href="/collections/coussins-assise">Coussins Assise</a></li>
        <li><a href="/collections/coussins-sommeil">Coussins Sommeil</a></li>
        <li><a href="/collections/packs">Packs économiques</a></li>
        <li><a href="/pages/a-propos">Notre histoire</a></li>
        <li><a href="/blogs/conseils">Conseils & Guides</a></li>
      </ul>
    </div>

    <!-- Colonne 3 : Aide -->
    <div class="da-footer__col">
      <h3 class="da-footer__col-title">Aide</h3>
      <ul class="da-footer__links">
        <li><a href="/pages/suivi-commande">Suivre ma commande</a></li>
        <li><a href="/pages/livraison">Politique de retour</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/pages/contact">Nous contacter</a></li>
      </ul>
    </div>

    <!-- Colonne 4 : Informations -->
    <div class="da-footer__col">
      <h3 class="da-footer__col-title">Informations</h3>
      <ul class="da-footer__links">
        <li><a href="/pages/mentions-legales">Mentions légales</a></li>
        <li><a href="/pages/cgv">CGV</a></li>
        <li><a href="/pages/confidentialite">Politique de confidentialité</a></li>
        <li><a href="/pages/engagements">Nos engagements</a></li>
      </ul>

      <!-- Paiement sécurisé -->
      <div class="da-footer__payment">
        <p class="da-footer__payment-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Paiement 100% sécurisé
        </p>
        <div class="da-footer__payment-badges">
          <span class="da-footer__payment-badge" title="Carte Bancaire">CB</span>
          <span class="da-footer__payment-badge" title="Visa">Visa</span>
          <span class="da-footer__payment-badge" title="Mastercard">MC</span>
          <span class="da-footer__payment-badge" title="PayPal">PayPal</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Bas de footer -->
  <div class="da-footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</span>
    <span class="da-footer__bottom-links">
      <a href="/pages/cgv">CGV</a>
      <span aria-hidden="true">·</span>
      <a href="/pages/mentions-legales">Mentions légales</a>
      <span aria-hidden="true">·</span>
      <a href="/pages/confidentialite">Confidentialité</a>
    </span>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page DA",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (footer)"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "contact@douceurdassise.fr"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telephone",
      "default": "01 86 26 10 20"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Adresse",
      "default": "Paris, France"
    }
  ]
}
{% endschema %}
