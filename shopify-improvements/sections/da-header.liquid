<header class="da-header">
  <!-- Top bar -->
  <div class="da-header__topbar">
    <div class="da-header__topbar-inner">
      <span class="da-header__topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Entreprise française
      </span>
      <span class="da-header__topbar-sep">•</span>
      <a href="tel:+33186261020" class="da-header__topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        01 86 26 10 20
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="da-header__nav" aria-label="Navigation principale">
    <div class="da-header__nav-inner">
      <!-- Logo -->
      <div class="da-header__logo">
        <a href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            <img 
              src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
              alt="{{ shop.name }}"
              width="{{ section.settings.logo_width }}"
              height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
              loading="eager"
            >
          {%- else -%}
            Douceur d'Assise
          {%- endif -%}
        </a>
      </div>

      <!-- Desktop links -->
      <div class="da-header__links">
        <a href="{{ routes.root_url }}">Accueil</a>
        <a href="{{ routes.all_products_collection_url }}">Catalogue</a>
        <a href="{{ pages['a-propos'].url | default: '/pages/a-propos' }}">À propos</a>
        <a href="{{ pages['contact'].url | default: '/pages/contact' }}">Contact</a>
      </div>

      <!-- Right actions -->
      <div class="da-header__actions">
        <!-- Cart button with animated badge -->
        <a href="{{ routes.cart_url }}" class="da-header__cart" id="da-cart-btn" aria-label="Panier">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="da-header__cart-label">Panier</span>
          <span class="da-header__cart-badge" id="da-cart-badge" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
            {{ cart.item_count }}
          </span>
        </a>

        <!-- Mobile burger -->
        <button
          type="button"
          class="da-header__burger"
          id="da-burger"
          aria-controls="da-mobile-menu"
          aria-expanded="false"
          aria-label="Ouvrir le menu"
        >
          <svg id="da-icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="da-icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu with smooth animation -->
    <div class="da-header__mobile" id="da-mobile-menu" aria-hidden="true">
      <div class="da-header__mobile-inner">
        <a href="{{ routes.root_url }}">Accueil</a>
        <a href="{{ routes.all_products_collection_url }}">Catalogue</a>
        <a href="{{ pages['a-propos'].url | default: '/pages/a-propos' }}">À propos</a>
        <a href="{{ pages['contact'].url | default: '/pages/contact' }}">Contact</a>
        <a href="{{ routes.cart_url }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline; vertical-align: middle; margin-right: 0.5rem;">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          Panier ({{ cart.item_count }})
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
(function() {
  // Mobile menu toggle
  var btn = document.getElementById('da-burger');
  var menu = document.getElementById('da-mobile-menu');
  var iconM = document.getElementById('da-icon-menu');
  var iconX = document.getElementById('da-icon-close');
  
  if (btn && menu) {
    btn.addEventListener('click', function() {
      var open = menu.classList.toggle('is-open');
      menu.setAttribute('aria-hidden', !open);
      btn.setAttribute('aria-expanded', open);
      btn.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      if (iconM) iconM.style.display = open ? 'none' : '';
      if (iconX) iconX.style.display = open ? '' : 'none';
    });
  }

  // Cart badge animation on update
  var badge = document.getElementById('da-cart-badge');
  if (badge) {
    // Listen for cart updates (Shopify Section Rendering API)
    document.addEventListener('cart:updated', function(e) {
      var count = e.detail && e.detail.item_count;
      if (typeof count !== 'undefined') {
        badge.textContent = count;
        badge.style.display = count > 0 ? '' : 'none';
        // Trigger pulse animation
        badge.classList.remove('is-updating');
        void badge.offsetWidth; // Force reflow
        badge.classList.add('is-updating');
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "En-tete DA",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 160
    }
  ]
}
{% endschema %}
