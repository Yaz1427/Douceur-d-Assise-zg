{% comment %}
  Douceur d'Assise - Cart Drawer Amélioré
  
  Includes:
  - Free shipping progress bar
  - Trust badges
  - Quantity controls with animations
  - Modern design aligned with the Next.js app
  
  Usage: Include in theme.liquid or as a section
{% endcomment %}

<!-- Cart Drawer Overlay -->
<div class="da-cart-drawer__overlay" id="da-cart-overlay"></div>

<!-- Cart Drawer -->
<aside class="da-cart-drawer" id="da-cart-drawer" aria-label="Panier" aria-hidden="true">
  <!-- Header -->
  <header class="da-cart-drawer__header">
    <h2>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline; vertical-align: middle; margin-right: 0.5rem;">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      Votre Panier
      <span id="da-cart-count">({{ cart.item_count }})</span>
    </h2>
    <button type="button" class="da-cart-drawer__close" id="da-cart-close" aria-label="Fermer le panier">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </header>

  <!-- Free Shipping Progress -->
  {%- assign free_shipping_threshold = 5000 -%}
  {%- assign cart_total = cart.total_price -%}
  {%- assign remaining = free_shipping_threshold | minus: cart_total -%}
  {%- assign progress_percent = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
  {%- if progress_percent > 100 -%}
    {%- assign progress_percent = 100 -%}
  {%- endif -%}
  
  <div class="da-cart-drawer__progress" id="da-cart-progress">
    {%- if remaining > 0 -%}
      <p class="da-cart-drawer__progress-text">
        Plus que <strong>{{ remaining | money }}</strong> pour la livraison gratuite !
      </p>
    {%- else -%}
      <p class="da-cart-drawer__progress-text">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline; vertical-align: middle; margin-right: 0.25rem; color: var(--success);">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <strong>Livraison gratuite débloquée !</strong>
      </p>
    {%- endif -%}
    <div class="da-cart-drawer__progress-bar">
      <div class="da-cart-drawer__progress-fill" style="width: {{ progress_percent }}%;"></div>
    </div>
  </div>

  <!-- Cart Items -->
  <div class="da-cart-drawer__items" id="da-cart-items">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="da-cart-drawer__item" data-line-key="{{ item.key }}">
          <!-- Image -->
          <div class="da-cart-drawer__item-image">
            {%- if item.image -%}
              <img 
                src="{{ item.image | image_url: width: 200 }}" 
                alt="{{ item.title | escape }}"
                width="80"
                height="80"
                loading="lazy"
              >
            {%- endif -%}
          </div>

          <!-- Info -->
          <div class="da-cart-drawer__item-info">
            <a href="{{ item.url }}" class="da-cart-drawer__item-title">
              {{ item.product.title | escape }}
            </a>
            {%- if item.variant.title != 'Default Title' -%}
              <p class="da-cart-drawer__item-variant">{{ item.variant.title }}</p>
            {%- endif -%}
            <p class="da-cart-drawer__item-price">{{ item.final_line_price | money }}</p>

            <!-- Quantity controls -->
            <div class="da-cart-drawer__quantity">
              <button 
                type="button" 
                class="da-cart-drawer__qty-btn" 
                data-action="decrease"
                data-key="{{ item.key }}"
                data-qty="{{ item.quantity | minus: 1 }}"
                aria-label="Diminuer la quantité"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <span class="da-cart-drawer__qty-value">{{ item.quantity }}</span>
              <button 
                type="button" 
                class="da-cart-drawer__qty-btn" 
                data-action="increase"
                data-key="{{ item.key }}"
                data-qty="{{ item.quantity | plus: 1 }}"
                aria-label="Augmenter la quantité"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Remove button -->
          <button 
            type="button" 
            class="da-cart-drawer__remove" 
            data-action="remove"
            data-key="{{ item.key }}"
            aria-label="Supprimer {{ item.product.title | escape }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
            </svg>
          </button>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="da-cart-drawer__empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p>Votre panier est vide</p>
        <a href="{{ routes.all_products_collection_url }}" class="da-btn da-btn-primary" id="da-cart-continue">
          Découvrir nos produits
        </a>
      </div>
    {%- endif -%}
  </div>

  <!-- Footer -->
  {%- if cart.item_count > 0 -%}
    <footer class="da-cart-drawer__footer">
      <!-- Trust badges -->
      <div class="da-cart-drawer__trust">
        <span class="da-cart-drawer__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          Livraison gratuite
        </span>
        <span class="da-cart-drawer__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Garantie 30 jours
        </span>
        <span class="da-cart-drawer__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Paiement sécurisé
        </span>
      </div>

      <!-- Total -->
      <div class="da-cart-drawer__total">
        <span class="da-cart-drawer__total-label">Total</span>
        <span class="da-cart-drawer__total-value" id="da-cart-total">{{ cart.total_price | money }}</span>
      </div>

      <!-- Checkout button -->
      <a href="{{ routes.cart_url }}" class="da-btn da-btn-outline da-cart-drawer__checkout" style="margin-bottom: 0.75rem;">
        Voir le panier
      </a>
      <a href="/checkout" class="da-btn da-btn-primary da-cart-drawer__checkout">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.5rem;">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Commander
      </a>
    </footer>
  {%- endif -%}
</aside>

<script>
(function() {
  var drawer = document.getElementById('da-cart-drawer');
  var overlay = document.getElementById('da-cart-overlay');
  var closeBtn = document.getElementById('da-cart-close');
  var cartBtn = document.getElementById('da-cart-btn');
  var continueBtn = document.getElementById('da-cart-continue');

  if (!drawer) return;

  function openDrawer() {
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('is-visible');
    document.body.style.overflow = '';
  }

  // Open drawer on cart button click
  if (cartBtn) {
    cartBtn.addEventListener('click', function(e) {
      e.preventDefault();
      openDrawer();
    });
  }

  // Close drawer
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);
  if (continueBtn) continueBtn.addEventListener('click', closeDrawer);

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) {
      closeDrawer();
    }
  });

  // Quantity buttons
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    
    var action = btn.dataset.action;
    var key = btn.dataset.key;
    var qty = parseInt(btn.dataset.qty, 10);

    if (action === 'remove') qty = 0;

    // Update cart via Shopify AJAX API
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function(res) { return res.json(); })
    .then(function(cart) {
      // Dispatch custom event for other components to listen
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      
      // Reload the drawer content (simple approach)
      // For a smoother UX, you could update the DOM directly
      location.reload();
    })
    .catch(function(err) {
      console.error('Cart update failed:', err);
    });
  });

  // Listen for add-to-cart events to open drawer
  document.addEventListener('cart:add', function() {
    openDrawer();
  });
})();
</script>
