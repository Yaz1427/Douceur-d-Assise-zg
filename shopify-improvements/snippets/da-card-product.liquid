{% comment %}
  Douceur d'Assise - Card Produit Améliorée
  
  Accepts:
  - card_product: {Object} Product Liquid object
  - lazy_load: {Boolean} Image should be lazy loaded. Default: true
  - show_secondary_image: {Boolean} Show secondary image on hover. Default: false
  - show_badges: {Boolean} Show trust badges. Default: true
  
  Usage:
  {% render 'da-card-product', card_product: product %}
{% endcomment %}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif
    assign show_badges = show_badges | default: true
  -%}

  <div class="da-product-card">
    <a href="{{ card_product.url }}" class="da-product-card__link">
      <!-- Image -->
      <div class="da-product-card__media">
        {%- if card_product.featured_media -%}
          <img
            src="{{ card_product.featured_media | image_url: width: 600 }}"
            alt="{{ card_product.featured_media.alt | escape | default: card_product.title }}"
            width="600"
            height="{{ 600 | divided_by: ratio | round }}"
            loading="{{ lazy_load | default: true | ternary: 'lazy', 'eager' }}"
            class="da-product-card__image da-product-card__image--primary"
          >
          {%- if card_product.media[1] != null and show_secondary_image -%}
            <img
              src="{{ card_product.media[1] | image_url: width: 600 }}"
              alt="{{ card_product.media[1].alt | escape | default: card_product.title }}"
              width="600"
              height="{{ 600 | divided_by: card_product.media[1].aspect_ratio | round }}"
              loading="lazy"
              class="da-product-card__image da-product-card__image--secondary"
            >
          {%- endif -%}
        {%- else -%}
          <div class="da-product-card__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'da-product-card__placeholder-svg' }}
          </div>
        {%- endif -%}

        <!-- Sale badge -->
        {%- if card_product.compare_at_price > card_product.price and card_product.available -%}
          {%- assign savings = card_product.compare_at_price | minus: card_product.price -%}
          {%- assign savings_percent = savings | times: 100 | divided_by: card_product.compare_at_price | round -%}
          <span class="da-product-card__badge da-product-card__badge--sale">
            -{{ savings_percent }}%
          </span>
        {%- endif -%}

        <!-- Sold out badge -->
        {%- if card_product.available == false -%}
          <span class="da-product-card__badge da-product-card__badge--soldout">
            Épuisé
          </span>
        {%- endif -%}
      </div>

      <!-- Content -->
      <div class="da-product-card__content">
        <!-- Title -->
        <h3 class="da-product-card__title">
          {{ card_product.title | escape }}
        </h3>

        <!-- Short description (from metafield if available) -->
        {%- if card_product.metafields.custom.short_description -%}
          <p class="da-product-card__description">
            {{ card_product.metafields.custom.short_description | truncate: 80 }}
          </p>
        {%- endif -%}

        <!-- Price -->
        <div class="da-product-card__price">
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="da-product-card__price-compare">
              {{ card_product.compare_at_price | money }}
            </span>
          {%- endif -%}
          <span class="da-product-card__price-current">
            {{ card_product.price | money }}
          </span>
        </div>

        <!-- Free shipping badge -->
        <div class="da-product-card__shipping">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          Livraison GRATUITE
        </div>

        <!-- Trust badges -->
        {%- if show_badges -%}
          <div class="da-product-card__trust">
            <span class="da-product-card__trust-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              Garantie 30j
            </span>
            <span class="da-product-card__trust-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72"/>
              </svg>
              SAV Français
            </span>
          </div>
        {%- endif -%}
      </div>
    </a>
  </div>

  <style>
    .da-product-card {
      background-color: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      overflow: hidden;
      transition: box-shadow var(--transition-base), transform var(--transition-base);
    }
    .da-product-card:hover {
      box-shadow: 0 10px 30px rgba(0,0,0,0.12);
      transform: translateY(-4px);
    }

    .da-product-card__link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .da-product-card__media {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
      background-color: var(--secondary-20);
    }

    .da-product-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-slow);
    }
    .da-product-card:hover .da-product-card__image--primary {
      transform: scale(1.08);
    }

    .da-product-card__image--secondary {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity var(--transition-base);
    }
    .da-product-card:hover .da-product-card__image--secondary {
      opacity: 1;
    }

    .da-product-card__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--secondary-20);
    }
    .da-product-card__placeholder-svg {
      width: 60%;
      height: 60%;
      fill: var(--muted-foreground);
      opacity: 0.5;
    }

    .da-product-card__badge {
      position: absolute;
      top: 0.75rem;
      left: 0.75rem;
      padding: 0.25rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      border-radius: var(--radius-full);
      z-index: 1;
    }
    .da-product-card__badge--sale {
      background-color: var(--destructive);
      color: var(--destructive-foreground);
    }
    .da-product-card__badge--soldout {
      background-color: var(--muted);
      color: var(--muted-foreground);
    }

    .da-product-card__content {
      padding: 1rem 1.25rem 1.5rem;
    }

    .da-product-card__title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--foreground);
      margin: 0 0 0.25rem;
      line-height: 1.3;
      transition: color var(--transition-fast);
    }
    .da-product-card:hover .da-product-card__title {
      color: var(--primary);
    }

    .da-product-card__description {
      font-size: 1rem;
      color: var(--muted-foreground);
      margin: 0 0 0.75rem;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .da-product-card__price {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }
    .da-product-card__price-current {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary);
    }
    .da-product-card__price-compare {
      font-size: 1.125rem;
      color: var(--muted-foreground);
      text-decoration: line-through;
    }

    .da-product-card__shipping {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--success);
      padding: 0.375rem 0.75rem;
      background-color: var(--success-10);
      border-radius: var(--radius-full);
      margin-bottom: 0.75rem;
    }
    .da-product-card__shipping svg {
      flex-shrink: 0;
    }

    .da-product-card__trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .da-product-card__trust-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.8125rem;
      color: var(--muted-foreground);
      padding: 0.25rem 0.5rem;
      background-color: var(--muted);
      border-radius: var(--radius);
    }
    .da-product-card__trust-badge svg {
      color: var(--success);
      flex-shrink: 0;
    }
  </style>
{%- endif -%}
